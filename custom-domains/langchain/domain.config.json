  },

  "ui": {
    "color": "#10B981",
    "icon": "🦜",
    "entityIcons": {
      "Agent": "🤖",
      "Graph": "🕸️",
      "Node": "⚙️",
      "Tool": "🔧",
      "State": "📊",
      "Model": "🧠",
      "StateField": "📝",
      "Checkpointer": "💾"
    }
  },
