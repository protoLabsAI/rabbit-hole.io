# Rabbit Hole Research Platform - Environment Variables
# Copy this file to .env.research and fill in your API keys
#
# Usage: docker compose -f docker-compose.research.yml --env-file .env.research up -d

# === REQUIRED: At least one LLM provider ===

# Anthropic (recommended for research agent)
ANTHROPIC_API_KEY=

# OpenAI (used for embeddings and fallback)
OPENAI_API_KEY=

# === VECTOR SEARCH: Qdrant + Ollama embeddings ===
# Both services run on protolabs AI stack, reachable via Tailscale MagicDNS.
# qwen3-embedding:0.6b must be pulled on protolabs: ollama pull qwen3-embedding:0.6b
QDRANT_URL=http://protolabs:6333
OLLAMA_ENDPOINT=http://protolabs:11434
# EMBED_MODEL=qwen3-embedding:0.6b

# === SEARCH: SearXNG (optional — enables web search) ===
# Set SEARXNG_ENDPOINT to enable web search. Without it the app runs graph-only.
# Self-hosted: docker compose -f docker-compose.research.yml up -d (uses port 8888)
# Then set: SEARXNG_ENDPOINT=http://localhost:8888
SEARXNG_ENDPOINT=

# === OPTIONAL: Additional providers ===

# Groq (fast inference, used for transcription)
GROQ_API_KEY=

# === OPTIONAL: Authentication ===

# Clerk (if you want user auth; skip for local-only use)
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=

# === OPTIONAL: MinIO encryption ===

# Generate with: openssl rand -base64 32
# MINIO_KMS_SECRET_KEY=minio-default-key:<your-base64-key>
