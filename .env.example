# rabbit-hole.io — self-host environment
#
# Copy to .env and fill in. Then: docker compose up -d

# ─── Required ─────────────────────────────────────────────────────────
# At least one LLM provider key.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ─── Database / storage credentials (defaults are fine for local) ─────
POSTGRES_PASSWORD=changeme
POSTGRES_JOB_PASSWORD=changeme
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=changeme

# ─── Recommended ──────────────────────────────────────────────────────
# Self-hosted SearXNG instance for web search. Without this, the agent
# can only use Wikipedia. Run your own: https://searxng.github.io/searxng/
SEARXNG_ENDPOINT=

# Free Whisper transcription via Groq for audio uploads.
GROQ_API_KEY=

# ─── Optional: observability ──────────────────────────────────────────
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=https://cloud.langfuse.com

# ─── Optional: tuning ─────────────────────────────────────────────────
JOB_WORKERS=3
LOG_LEVEL=INFO

# ─── Optional: public BYOK demo (Cloudflare Tunnel) ───────────────────
# For demo.rabbit-hole.io. See docs/how-to/host-byok-demo.md for the full runbook.
#
# Token from Cloudflare Zero Trust → Tunnels. Only needed when running the
# docker-compose.tunnel.yml overlay.
CLOUDFLARE_TUNNEL_TOKEN=
#
# Strict BYOK: leave the server LLM key UNSET so every request must carry the
# visitor's own key (x-llm-api-key). Keep SEARXNG_ENDPOINT set so web search
# stays server-side and free.
#
# Turn on the per-IP rate limit for public traffic (no-op when unset/false).
RH_RATE_LIMIT_ENABLED=false
RH_RATE_LIMIT_MAX=30
RH_RATE_LIMIT_WINDOW_S=300
