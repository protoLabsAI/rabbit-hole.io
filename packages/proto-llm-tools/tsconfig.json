{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "strict": false,
    "noImplicitAny": false,
    "noEmitOnError": false,
    "jsx": "react-jsx",
    "lib": ["dom", "dom.iterable", "esnext"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "paths": {
      "@protolabsai/ui": ["../ui/src"],
      "@protolabsai/ui/atoms": ["../ui/src/atoms"],
      "@protolabsai/ui/hooks": ["../ui/src/hooks"],
      "@protolabsai/sidequest-utils/client": ["../sidequest-utils/src/client"],
      "@protolabsai/sidequest-utils/components": [
        "../sidequest-utils/src/components"
      ],
      "@protolabsai/icon-system": ["../icon-system/src"],
      "@protolabsai/llm-providers": ["../llm-providers/src"],
      "@protolabsai/types": ["../types/src"],
      "@protolabsai/utils": ["../utils/src"],
      "@protolabsai/llm-tools/client": ["./src/client"]
    },
    "composite": true,
    "incremental": true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "**/*.test.ts", "**/*.stories.tsx"],
  "references": [
    {
      "path": "../types"
    },
    {
      "path": "../ui"
    },
    {
      "path": "../sidequest-utils"
    },
    {
      "path": "../icon-system"
    },
    {
      "path": "../llm-providers"
    },
    {
      "path": "../utils"
    }
  ]
}
