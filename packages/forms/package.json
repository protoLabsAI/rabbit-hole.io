{
  "name": "@proto/forms",
  "version": "0.3.3",
  "type": "module",
  "description": "Domain entity form system with dynamic generation from Zod schemas",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist .turbo node_modules"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@proto/types": "workspace:*",
    "@proto/ui": "workspace:*",
    "react-hook-form": "^7.54.2",
    "zod": "^4.1.12"
  },
  "peerDependencies": {
    "react": "^19.0.0"
  },
  "devDependencies": {
    "@proto/config-typescript": "workspace:*",
    "@types/react": "^19.0.6",
    "tsup": "^8.0.1",
    "typescript": "^5.6.3"
  }
}
