{
  "name": "@protolabsai/sidequest-utils",
  "version": "0.1.6",
  "description": "Shared utilities for Sidequest.js job processing",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client/index.d.ts",
      "import": "./dist/client/index.js",
      "default": "./dist/client/index.js"
    },
    "./server": {
      "types": "./dist/server/index.d.ts",
      "import": "./dist/server/index.js",
      "default": "./dist/server/index.js"
    },
    "./components": {
      "types": "./dist/components/index.d.ts",
      "import": "./dist/components/index.js",
      "default": "./dist/components/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@protolabsai/database": "workspace:*",
    "@protolabsai/icon-system": "workspace:*",
    "@protolabsai/ui": "workspace:*",
    "@tanstack/react-query": "^5.90.2",
    "clsx": "^2.1.0",
    "tailwind-merge": "^2.5.4",
    "sidequest": "1.7.1"
  },
  "devDependencies": {
    "@types/node": "^22.16.5",
    "@types/react": "^19.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.4"
  },
  "peerDependencies": {
    "react": "^19.0.0"
  }
}
