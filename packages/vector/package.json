{
  "name": "@protolabsai/vector",
  "version": "0.1.0",
  "private": true,
  "description": "pgvector corpus search + gateway embedding utilities (Qdrant/graph legacy)",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@qdrant/js-client-rest": "^1.14.0",
    "graphology": "^0.26.0",
    "graphology-communities-louvain": "^2.0.2",
    "graphology-types": "^0.24.8"
  },
  "devDependencies": {
    "@types/node": "^22.18.3",
    "@types/pg": "^8.11.0",
    "pg": "^8.16.3",
    "tsup": "^8.0.1",
    "typescript": "^5.5.4"
  }
}
