{
  "name": "@protolabsai/charts",
  "version": "0.1.5",
  "private": true,
  "description": "Chart components for data visualization",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./gantt": {
      "types": "./dist/gantt/index.d.ts",
      "import": "./dist/gantt/index.js",
      "default": "./dist/gantt/index.js"
    },
    "./map": {
      "types": "./dist/map/index.d.ts",
      "import": "./dist/map/index.js",
      "default": "./dist/map/index.js"
    },
    "./map/utils": {
      "types": "./dist/map/utils.d.ts",
      "import": "./dist/map/utils.js",
      "default": "./dist/map/utils.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "type-check": "tsc --noEmit",
    "test": "vitest",
    "lint": "eslint . --max-warnings 0"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@protolabsai/icon-system": "workspace:*",
    "@protolabsai/types": "workspace:*",
    "@protolabsai/ui": "workspace:*",
    "@protolabsai/utils": "workspace:*",
    "@uidotdev/usehooks": "^2.4.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "jotai": "^2.10.3",
    "leaflet": "^1.9.4",
    "lodash.throttle": "^4.1.1",
    "react": "^19.0.0",
    "tailwind-merge": "^2.6.0"
  },
  "devDependencies": {
    "@types/leaflet": "^1.9.20",
    "@types/lodash.throttle": "^4.1.9",
    "@types/react": "^19.0.0",
    "tsup": "^8.0.1",
    "typescript": "^5.6.3",
    "vitest": "^3.2.4"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "type": "module"
}
