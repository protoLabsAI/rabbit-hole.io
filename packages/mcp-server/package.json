{
  "name": "@protolabsai/mcp-server",
  "version": "0.1.0",
  "type": "module",
  "description": "MCP server for Rabbit Hole research and media processing tools",
  "bin": {
    "rabbit-hole-mcp": "./dist/index.js",
    "rabbit-hole-mcp-http": "./dist/http-server.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/index.ts",
    "dev:http": "tsx src/http-server.ts",
    "start": "node dist/index.js",
    "start:http": "node dist/http-server.js",
    "test": "vitest run"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "langfuse": "^3.38.6"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsup": "^8.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "vitest": "^2.0.0"
  }
}
