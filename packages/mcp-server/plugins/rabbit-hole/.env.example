# Rabbit Hole Root Directory (absolute path to your rabbit-hole.io repo)
# Required for MCP server to locate dist/index.js
RABBIT_HOLE_ROOT=/path/to/your/rabbit-hole.io

# Anthropic API Key (for entity extraction)
# Get from: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Job Processor URL (for media ingestion — requires Docker services)
# Default: http://localhost:8680
# Start with: docker compose -f docker-compose.research.yml up -d
JOB_PROCESSOR_URL=http://localhost:8680

# Tavily API Key (optional — premium web search)
# Get from: https://tavily.com/
# If not set, web_search uses DuckDuckGo (free, no key required)
TAVILY_API_KEY=

# Groq API Key (optional — free audio transcription)
# Get from: https://console.groq.com/
GROQ_API_KEY=
