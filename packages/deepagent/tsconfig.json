{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "strict": false,
    "noImplicitAny": false,
    "noEmitOnError": false,
    "module": "esnext",
    "moduleResolution": "bundler",
    "paths": {
      "@protolabsai/llm-providers": ["../llm-providers/src"],
      "@protolabsai/llm-providers/*": ["../llm-providers/src/*"],
      "@protolabsai/observability": ["../observability/src"],
      "@protolabsai/types": ["../types/src"],
      "@protolabsai/vector": ["../vector/src"],
      "@protolabsai/vector/*": ["../vector/src/*"],
      "@protolabsai/database": ["../database/src"],
      "@protolabsai/database/*": ["../database/src/*"],
      "@protolabsai/utils": ["../utils/src"],
      "@protolabsai/utils/*": ["../utils/src/*"]
    },
    "composite": true,
    "incremental": true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "**/*.test.ts"],
  "references": [
    { "path": "../types" },
    { "path": "../llm-providers" },
    { "path": "../observability" },
    { "path": "../vector" },
    { "path": "../database" },
    { "path": "../utils" }
  ]
}
