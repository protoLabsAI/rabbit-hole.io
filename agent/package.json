{
  "name": "@protolabsai/agent",
  "version": "0.2.0",
  "type": "module",
  "description": "",
  "main": "index.js",
  "scripts": {
    "dev": "pnpm exec langgraphjs dev --port 8123",
    "dev:nodemon": "nodemon",
    "dev:a2a": "tsx watch src/a2a-main.ts",
    "start:langgraph": "pnpm exec langgraphjs dev --port 8123",
    "start:a2a": "node dist/a2a-main.js",
    "dev:proxy-logger": "tsx src/debug-http-logger.ts",
    "dev:enhanced": "./scripts/dev-agent.sh",
    "build": "tsc",
    "build:watch": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:person-research": "curl -X POST http://localhost:8123/person_research_agent/invoke -H 'Content-Type: application/json' -d '{\"input\":{\"targetPersonName\":\"Test Person\",\"existingPersonEntities\":[],\"existingRelationships\":[]}}'",
    "health": "curl http://localhost:8123/docs",
    "clean": "rm -rf dist node_modules",
    "type-check": "tsc --noEmit"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@langchain/langgraph-cli": "^1.1.2",
    "@types/html-to-text": "^9.0.4",
    "@types/node": "^25.6.0",
    "nodemon": "^3.1.10",
    "tsx": "^4.20.5",
    "typescript": "^5.9.3",
    "vitest": "^1.6.1"
  },
  "dependencies": {
    "@copilotkit/sdk-js": "^1.9.1",
    "@langchain/anthropic": "^1.3.26",
    "@langchain/community": "^1.1.27",
    "@langchain/core": "^1.1.42",
    "@langchain/google-genai": "^1.0.0",
    "@langchain/langgraph": "^1.2.8",
    "@langchain/langgraph-checkpoint": "~0.0.18",
    "@langchain/openai": "^1.4.4",
    "@langfuse/langchain": "^5.1.0",
    "@langfuse/otel": "^5.1.0",
    "@opentelemetry/resources": "^2.2.0",
    "@opentelemetry/sdk-node": "^0.208.0",
    "@opentelemetry/semantic-conventions": "^1.38.0",
    "@protolabsai/deepagent": "workspace:*",
    "@protolabsai/llm-providers": "workspace:*",
    "@protolabsai/llm-tools": "workspace:*",
    "@protolabsai/types": "workspace:*",
    "@protolabsai/utils": "workspace:*",
    "dotenv": "^17.4.2",
    "zod": "^4.3.6"
  }
