{
  "extends": "../../packages/config-typescript/nextjs.json",
  "compilerOptions": {
    "baseUrl": ".",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "jsx": "preserve",
    "paths": {
      "@/*": ["./app/*"],
      "@protolabsai/types": ["../../packages/types/src"],
      "@protolabsai/database": ["../../packages/database/src"],
      "@protolabsai/auth": ["../../packages/auth/src"],
      "@protolabsai/auth/client": ["../../packages/auth/src/client"],
      "@protolabsai/utils": ["../../packages/utils/src"],
      "@protolabsai/utils/atlas": ["../../packages/utils/src/atlas"],
      "@protolabsai/utils/file-processing": [
        "../../packages/utils/src/file-processing"
      ],
      "@protolabsai/utils/tenancy-edge": [
        "../../packages/utils/src/tenancy-edge"
      ],
      "@protolabsai/utils/tenancy-server": [
        "../../packages/utils/src/tenancy-server"
      ],
      "@protolabsai/api-utils": ["../../packages/api-utils/src"],
      "@protolabsai/research-middleware": [
        "../../packages/research-middleware/src"
      ],
      "@protolabsai/logger": ["../../packages/logger/src"],
      "@protolabsai/sidequest-utils": ["../../packages/sidequest-utils/src"],
      "@protolabsai/sidequest-utils/client": [
        "../../packages/sidequest-utils/src/client"
      ],
      "@protolabsai/sidequest-utils/server": [
        "../../packages/sidequest-utils/src/server"
      ],
      "@protolabsai/icon-system": ["../../packages/icon-system/src"],
      "@protolabsai/llm-providers": ["../../packages/llm-providers/src"],
      "@protolabsai/ui": ["../../packages/ui/src"],
      "@protolabsai/ui/atoms": ["../../packages/ui/src/atoms"],
      "@protolabsai/ui/molecules": ["../../packages/ui/src/molecules"],
      "@protolabsai/ui/organisms": ["../../packages/ui/src/organisms"],
      "@protolabsai/ui/templates": ["../../packages/ui/src/templates"],
      "@protolabsai/ui/theme": ["../../packages/ui/src/theme"],
      "@protolabsai/charts": ["../../packages/charts/src"],
      "@protolabsai/charts/gantt": ["../../packages/charts/src/gantt"]
    }
  },
  "include": [
    "next-env.d.ts",
    "app/**/*.ts",
    "app/**/*.tsx",
    ".next/types/**/*.ts",
    "../../config/**/*.ts",
    "../../custom-domains/**/*.ts",
    "../../.generated/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    ".next",
    "**/__tests__/**",
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/*.spec.ts",
    "**/*.spec.tsx"
  ],
  "references": [
    { "path": "../../packages/types" },
    { "path": "../../packages/database" },
    { "path": "../../packages/auth" },
    { "path": "../../packages/ui" },
    { "path": "../../packages/utils" },
    { "path": "../../packages/api-utils" },
    { "path": "../../packages/logger" },
    { "path": "../../packages/icon-system" },
    { "path": "../../packages/proto-llm-tools" },
    { "path": "../../packages/llm-providers" },
    { "path": "../../packages/sidequest-utils" },
    { "path": "../../packages/charts" },
    { "path": "../../packages/research-middleware" }
  ]
}
